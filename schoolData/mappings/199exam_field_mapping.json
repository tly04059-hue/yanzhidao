  "global_rules": [
    "A-Z/AA columns are phase1 fields for miniapp yearly display and should be prioritized for completeness.",
    "Frontend may display label fields, but L1 must preserve code/name/label for school, department, major category, and major.",
    "Tuition source unit is ten-thousand yuan; L1 tuition fields use yuan.",
    "Direction must not include study mode words such as full-time or non-full-time.",
    "If any adjustment_admission_by_year.*.quota is greater than 0, adjustment should be derived as 是.",
    "Display order for program_type is MPA, MEM, MBA.",
    "Filter priority is program_type, province, city."
  ],
  "derived_fields": [
    {
      "target_path": "record_id",
      "rule": "Generate from program_type, school_code, department_code, major_code, direction code/name, study_mode, and batch/year."
    },
    {
      "target_path": "program_id",
      "rule": "Generate from 199 + program_type + school_code + batch/year."
    },
    {
      "target_path": "track_id",
      "rule": "Generate from school_code + department_code + major_code + direction + study_mode."
    },
    {
      "target_path": "latest_score",
      "rule": "Join total_score, english_score, comprehensive_score as total/english/comprehensive when values exist."
    },
    {
      "target_path": "school_level_display",
      "rule": "Map school_level to frontend display category: 985, 211, 双非."
    },
    {
      "target_path": "quality.completeness_score",
      "rule": "Calculate from phase1 required fields."
    }
  ],
