/* 与 BottomTabBar.vue 保持同步，修改时请同时更新 src/data/tabbar.ts */
.btb-wrap {
  display: none;
  justify-content: space-around;
  align-items: center;
  height: 100%;
  background: #FFFFFF;
  border-top: 1px solid rgba(138, 129, 117, 0.1);
  box-sizing: border-box;
}

.btb-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 6px;
  height: 100%;
  min-width: 72px;
}

.btb-icon {
  width: 23px;
  height: 23px;
}

.btb-text {
  font-size: 10px;
  font-weight: 400;
  color: #8A8175;
  line-height: 1.2;
}

.btb-item.active .btb-text {
  color: #CF7140;
}
